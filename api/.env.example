# Public base URL of this API (no trailing slash). Used to build OAuth redirect URLs.
# Local: http://localhost:3000
# Prod:  https://your-app.vercel.app
APP_BASE_URL=http://localhost:3000

# Slack app credentials (api.slack.com → Your App → Basic Information / OAuth & Permissions)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Must match the Redirect URL configured in Slack exactly:
# {APP_BASE_URL}/auth/slack/callback
SLACK_REDIRECT_URI=http://localhost:3000/auth/slack/callback

# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Prefer the service role key so the API can write tokens server-side.
# Never expose this to the Figma plugin or browser clients.
SUPABASE_SERVICE_ROLE_KEY=

# Free tier: max exact-name imports per workspace per calendar month
FREE_TIER_MONTHLY_LIMIT=50
